# Database (Neon Postgres - one click via Vercel marketplace)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Auth - your own password for logging in (this is a solo app)
APP_PASSWORD=change-me-to-something-long
SESSION_SECRET=generate-with-openssl-rand-base64-32

# Telnyx
TELNYX_API_KEY=KEY...                       # from portal.telnyx.com -> API Keys
TELNYX_SIP_USERNAME=your_sip_username       # from your Credential Connection
TELNYX_SIP_PASSWORD=your_sip_password
TELNYX_CONNECTION_ID=12345                  # numeric ID of the Credential Connection
TELNYX_PUBLIC_KEY=                          # for webhook signature verification (optional but recommended)

# Public base URL (set after deploying to Vercel; needed for webhook URL display)
NEXT_PUBLIC_APP_URL=http://localhost:3000
